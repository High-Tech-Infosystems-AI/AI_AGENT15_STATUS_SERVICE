{
	"info": {
		"name": "Notification Service",
		"description": "Complete API collection for the Notification Service.\n\n**Two modes:**\n- `/test/*` — No JWT required, uses `user_id` query param (for testing)\n- `/status/notifications/*` — JWT required via Bearer token (production)\n\n**Setup:**\n1. Set `base_url` variable to your Status Service URL (e.g. `http://localhost:8515`)\n2. For JWT endpoints: run the Login request first, it auto-sets the `token` variable\n3. For test endpoints: just run directly, no auth needed",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{"key": "base_url", "value": "http://localhost:8515", "type": "string"},
		{"key": "gateway_url", "value": "http://localhost:8050", "type": "string"},
		{"key": "auth_url", "value": "http://localhost:8085", "type": "string"},
		{"key": "token", "value": "", "type": "string"},
		{"key": "user_id", "value": "1", "type": "string"},
		{"key": "notification_id", "value": "1", "type": "string"},
		{"key": "schedule_id", "value": "1", "type": "string"}
	],
	"item": [
		{
			"name": "0. Auth",
			"description": "Login to get JWT token. Token is auto-saved to {{token}} variable.",
			"item": [
				{
					"name": "Login (get JWT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('token', json.access_token);",
									"    pm.collectionVariables.set('user_id', json.user_id);",
									"    console.log('Token saved. user_id=' + json.user_id);",
									"}",
									"pm.test('Login successful', function() {",
									"    pm.response.to.have.status(200);",
									"    pm.expect(json.access_token).to.exist;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"supriyohti\",\n    \"password\": \"891y29hdfabsf8128\"\n}"
						},
						"url": {"raw": "{{auth_url}}/ats/login", "host": ["{{auth_url}}"], "path": ["ats", "login"]}
					}
				}
			]
		},
		{
			"name": "1. Test APIs (No Auth)",
			"description": "No JWT needed. Pass `user_id` as query param. Hit Status Service directly.",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": {"raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"]}
					}
				},
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"url": {"raw": "{{base_url}}/test/users", "host": ["{{base_url}}"], "path": ["test", "users"]}
					}
				},
				{
					"name": "Get Notifications (user)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/test/notifications?user_id={{user_id}}&page=1&limit=20",
							"host": ["{{base_url}}"], "path": ["test", "notifications"],
							"query": [
								{"key": "user_id", "value": "{{user_id}}"},
								{"key": "page", "value": "1"},
								{"key": "limit", "value": "20"},
								{"key": "domain_type", "value": "", "disabled": true},
								{"key": "priority", "value": "", "disabled": true},
								{"key": "is_read", "value": "false", "disabled": true},
								{"key": "delivery_mode", "value": "", "disabled": true},
								{"key": "date_from", "value": "2026-04-01", "disabled": true},
								{"key": "date_to", "value": "2026-04-30", "disabled": true}
							]
						}
					}
				},
				{
					"name": "Get Unread Count",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/test/notifications/unread-count?user_id={{user_id}}",
							"host": ["{{base_url}}"], "path": ["test", "notifications", "unread-count"],
							"query": [{"key": "user_id", "value": "{{user_id}}"}]
						}
					}
				},
				{
					"name": "Get Active Banners",
					"request": {
						"method": "GET",
						"url": {"raw": "{{base_url}}/test/notifications/banners/active", "host": ["{{base_url}}"], "path": ["test", "notifications", "banners", "active"]}
					}
				},
				{
					"name": "Get Admin Logs",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/test/notifications/admin/logs?page=1&limit=20",
							"host": ["{{base_url}}"], "path": ["test", "notifications", "admin", "logs"],
							"query": [
								{"key": "page", "value": "1"},
								{"key": "limit", "value": "20"},
								{"key": "domain_type", "value": "", "disabled": true},
								{"key": "source_service", "value": "", "disabled": true},
								{"key": "priority", "value": "", "disabled": true},
								{"key": "visibility", "value": "", "disabled": true},
								{"key": "user_id", "value": "", "disabled": true},
								{"key": "date_from", "value": "", "disabled": true},
