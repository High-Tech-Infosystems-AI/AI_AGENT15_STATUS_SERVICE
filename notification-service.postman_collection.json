							"raw": "{\n    \"title\": \"Admin Alert\",\n    \"message\": \"This goes to all admins.\",\n    \"delivery_mode\": \"push\",\n    \"domain_type\": \"manual\",\n    \"visibility\": \"restricted\",\n    \"priority\": \"critical\",\n    \"target_type\": \"role\",\n    \"target_id\": \"super_admin,admin\"\n}"
